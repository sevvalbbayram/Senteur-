library(caret)
library(dplyr)
#RF
set.seed(123)
trainIndex <- createDataPartition(m$Mortality, p = 0.7, list = FALSE)
train <- m[trainIndex, ]
test <- m[-trainIndex, ]
ctrl <- trainControl(method = "cv",
number = 5)
train$Mortality <- factor(train$Mortality, levels = c("FALSE", "TRUE"))
test$Mortality <- factor(test$Mortality, levels = c("FALSE", "TRUE"))
rf <- train(Mortality ~ ., data = train, method = "rf",
metric = "Accuracy",
trControl = ctrl)
predrf <- predict(rf, newdata = test)
confusionMatrix(data = relevel(predrf, ref = "TRUE"),
reference = relevel(as.factor(test$Mortality), ref = "TRUE"),
positive = "TRUE",
mode = "everything")
