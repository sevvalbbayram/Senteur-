set.seed(123)
N <- 10000
d.boot <- numeric(N)
#Bootstrapping
for (i in 1:N) {
boot_aa <- sample(aa$Delay, size = length(aa), replace = TRUE)
boot_ua <- sample(ua$Delay, size = length(ua), replace = TRUE)
ratio.boot[i] <- mean(aa$Delay) / mean(ua$Delay)
}
org <- mean(aa$Delay) / mean(ua$Delay)
set.seed(123)
N <- 10000
d.boot <- numeric(N)
#Bootstrapping
for (i in 1:N) {
boot_aa <- sample(aa$Delay, size = length(aa), replace = TRUE)
boot_ua <- sample(ua$Delay, size = length(ua), replace = TRUE)
d.boot[i] <- mean(aa$Delay) / mean(ua$Delay)
}
# 95% confidence interval
quantile(ratio.boot, c(0.025,0.975))
