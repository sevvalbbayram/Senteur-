head(mor)
head(mor)
summary(mor)
m <- mor[ , -1]
m <- mor[ , -1]
g <-  <- glm(data = m, formula = Mortality ~ ., family = "binomial")
m <- mor[ , -1]
g <- glm(data = m, formula = Mortality ~ ., family = "binomial")
summary(g)
df.pred <- m %>% mutate(actual = Mortality,
default.prob = round(g$fitted.values, 4),
default.pred = ifelse(default.prob > 0.5, "T", "F")
)
plot.roc(x = df.pred$actual, predictor = g$fitted.values,
print.auc = TRUE,
threshold = "best",
print.thres = "best")
th <- data.frame(TPR = df.roc$sensitivities,
Specificity = df.roc$specificities,
FPR = 1 - df.roc$specificities,
Threshold = df.roc$thresholds)
par(pty = "s")
df.roc <- roc(response = df.pred$default,
predictor = g$fitted.values,
plot = TRUE,
percent = TRUE,
ci = TRUE,
legacy.axes = TRUE, # change the x-axis to 1-Specificity #xlab = "False Positive Percentage",
#ylab = "True Positive Percentage",
print.auc = TRUE,
print.auc.pattern = "%.2f (%.2f-%.2f)")
par(pty = "s")
df.roc <- roc(response = df.pred$actual,
predictor = g$fitted.values,
plot = TRUE,
percent = TRUE,
ci = TRUE,
legacy.axes = TRUE, # change the x-axis to 1-Specificity #xlab = "False Positive Percentage",
#ylab = "True Positive Percentage",
print.auc = TRUE,
print.auc.pattern = "%.2f (%.2f-%.2f)")
th <- data.frame(TPR = df.roc$sensitivities,
Specificity = df.roc$specificities,
FPR = 1 - df.roc$specificities,
Threshold = df.roc$thresholds)
head(th, 3)
th.opt <- th %>%
mutate(Combine = TPR+Specificity,
AUC = round(df.roc$auc,4)) %>% arrange(desc(Combine))
head(th.opt,10)
